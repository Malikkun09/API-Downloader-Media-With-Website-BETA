# Server Configuration
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# File Management
FILE_TTL_HOURS=24
COOKIES_DIR=cookies
DOWNLOADS_DIR=downloads

# API Keys - Ganti dengan key Anda sendiri
API_KEY_INTERNAL=YOUR_INT_KEY
API_KEY_PUBLIC=YOUR_PUB_KEY
API_KEY_DEVELOPMENT=YOUR_DEV_KEY
API_KEY_PRODUCTION=YOUR_PRO_KEY

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
